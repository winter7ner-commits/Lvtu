<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bitzh.lvtu.mapper.LegalDocumentMapper">

    <resultMap id="BaseResultMap" type="com.bitzh.lvtu.entity.LegalDocument">
        <id column="id" property="id"/>
        <result column="title" property="name"/>
        <result column="category_id" property="categoryId"/>
        <result column="publish_date" property="publishDate"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, title, category_id, publish_date, sort_order, status, created_at, updated_at
    </sql>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM legal_document ORDER BY category_id, sort_order
    </select>

    <select id="findByCategoryId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM legal_document WHERE category_id = #{categoryId} ORDER BY sort_order
    </select>

    <select id="findById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/> FROM legal_document WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="com.bitzh.lvtu.entity.LegalDocument" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO legal_document (title, category_id, publish_date, sort_order, status, created_at, updated_at)
        VALUES (#{name}, #{categoryId}, #{publishDate}, #{sortOrder}, #{status}, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
    </insert>

    <update id="update" parameterType="com.bitzh.lvtu.entity.LegalDocument">
        UPDATE legal_document
        <set>
            <if test="name != null">title = #{name},</if>
            <if test="categoryId != null">category_id = #{categoryId},</if>
            <if test="publishDate != null">publish_date = #{publishDate},</if>
            <if test="sortOrder != null">sort_order = #{sortOrder},</if>
            <if test="status != null">status = #{status},</if>
            updated_at = CURRENT_TIMESTAMP
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM legal_document WHERE id = #{id}
    </delete>

</mapper>
