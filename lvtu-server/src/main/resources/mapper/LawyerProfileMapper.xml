<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bitzh.lvtu.mapper.LawyerProfileMapper">

    <resultMap id="lawyerProfileMap" type="com.bitzh.lvtu.entity.LawyerProfile">
        <id property="lawyerId" column="lawyer_id"/>
        <result property="userId" column="user_id"/>
        <result property="licenseNo" column="license_no"/>
        <result property="lawFirm" column="law_firm"/>
        <result property="bio" column="bio"/>
        <result property="status" column="status"/>
        <result property="practiceYears" column="practice_years"/>
    </resultMap>

    <select id="selectByLawyerId" resultMap="lawyerProfileMap">
        SELECT lawyer_id, user_id, license_no, law_firm, bio, status, practice_years
        FROM lawyer
        WHERE lawyer_id = #{lawyerId}
          AND status = 1
    </select>

    <select id="selectByUserId" resultMap="lawyerProfileMap">
        SELECT lawyer_id, user_id, license_no, law_firm, bio, status, practice_years
        FROM lawyer
        WHERE user_id = #{userId}
          AND status = 1
    </select>

</mapper>
