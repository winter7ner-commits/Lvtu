<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bitzh.lvtu.mapper.ServiceResultSubmissionMapper">

    <resultMap id="submissionMap" type="com.bitzh.lvtu.entity.ServiceResultSubmission">
        <id property="id" column="id"/>
        <result property="orderId" column="order_id"/>
        <result property="resultId" column="result_id"/>
        <result property="lawyerId" column="lawyer_id"/>
        <result property="submissionNo" column="submission_no"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <resultMap id="submissionAttachmentMap" type="com.bitzh.lvtu.entity.ServiceResultSubmissionAttachment">
        <id property="id" column="id"/>
        <result property="submissionId" column="submission_id"/>
        <result property="fileName" column="file_name"/>
        <result property="fileUrl" column="file_url"/>
        <result property="fileType" column="file_type"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id" keyColumn="id">
        INSERT INTO service_result_submission (
            order_id,
            result_id,
            lawyer_id,
            submission_no,
            title,
            content
        ) VALUES (
            #{orderId},
            #{resultId},
            #{lawyerId},
            #{submissionNo},
            #{title},
            #{content}
        )
    </insert>

    <select id="countByOrderId" resultType="int">
        SELECT COUNT(*)
        FROM service_result_submission
        WHERE order_id = #{orderId}
    </select>

    <select id="selectByOrderId" resultMap="submissionMap">
        SELECT id, order_id, result_id, lawyer_id, submission_no, title, content, created_at
        FROM service_result_submission
        WHERE order_id = #{orderId}
        ORDER BY submission_no DESC, created_at DESC, id DESC
    </select>

    <insert id="batchInsertAttachments">
        INSERT INTO service_result_submission_attachment (submission_id, file_name, file_url, file_type)
        VALUES
        <foreach collection="attachments" item="item" separator=",">
            (#{item.submissionId}, #{item.fileName}, #{item.fileUrl}, #{item.fileType})
        </foreach>
    </insert>

    <select id="selectAttachmentsBySubmissionIds" resultMap="submissionAttachmentMap">
        SELECT id, submission_id, file_name, file_url, file_type, created_at
        FROM service_result_submission_attachment
        WHERE submission_id IN
        <foreach collection="submissionIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY id ASC
    </select>
</mapper>
