<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bitzh.lvtu.mapper.ServiceResultAttachmentMapper">

    <resultMap id="attachmentMap" type="com.bitzh.lvtu.entity.ServiceResultAttachment">
        <id property="id" column="id"/>
        <result property="resultId" column="result_id"/>
        <result property="fileName" column="file_name"/>
        <result property="fileUrl" column="file_url"/>
        <result property="fileType" column="file_type"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <insert id="batchInsert">
        INSERT INTO service_result_attachment (result_id, file_name, file_url, file_type)
        VALUES
        <foreach collection="attachments" item="item" separator=",">
            (#{item.resultId}, #{item.fileName}, #{item.fileUrl}, #{item.fileType})
        </foreach>
    </insert>

    <select id="selectByResultId" resultMap="attachmentMap">
        SELECT id, result_id, file_name, file_url, file_type, created_at
        FROM service_result_attachment
        WHERE result_id = #{resultId}
        ORDER BY id ASC
    </select>

    <delete id="deleteByResultId">
        DELETE FROM service_result_attachment
        WHERE result_id = #{resultId}
    </delete>

</mapper>
