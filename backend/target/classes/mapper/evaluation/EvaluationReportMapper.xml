<?xml version=""1.0"" encoding=""UTF-8"" ?>
<!DOCTYPE mapper PUBLIC ""-//mybatis.org//DTD Mapper 3.0//EN"" ""http://mybatis.org/dtd/mybatis-3-mapper.dtd"">
<mapper namespace=""com.bitzh.lvtu.mapper.evaluation.EvaluationReportMapper"">

    <resultMap id=""EvaluationReportResultMap"" type=""com.bitzh.lvtu.entity.evaluation.EvaluationReport"">
        <id property=""reportId"" column=""report_id""/>
        <result property=""evaluationId"" column=""evaluation_id""/>
        <result property=""reporterId"" column=""reporter_id""/>
        <result property=""reason"" column=""reason""/>
        <result property=""description"" column=""description""/>
        <result property=""status"" column=""status""/>
        <result property=""createdTime"" column=""created_time""/>
    </resultMap>

    <insert id=""insert"">
        INSERT INTO evaluation_report (
            evaluation_id,
            reporter_id,
            reason,
            description,
            status
        ) VALUES (
            #{evaluationId},
            #{reporterId},
            #{reason.value},
            #{description},
            #{status.value}
        )
    </insert>

    <select id=""findByEvaluationId"" resultMap=""EvaluationReportResultMap"">
        SELECT * FROM evaluation_report
        WHERE evaluation_id = #{evaluationId}
        ORDER BY created_time DESC
    </select>

    <select id=""findByEvaluationIdAndReporterId"" resultMap=""EvaluationReportResultMap"">
        SELECT * FROM evaluation_report
        WHERE evaluation_id = #{evaluationId} AND reporter_id = #{reporterId}
    </select>
</mapper>
